[user]
	name = Ryan Finnie
	email = ryan@finnie.org

[init]
	defaultBranch = main

[alias]
	new = !git init && git symbolic-ref HEAD refs/heads/main
	touch = commit --amend --date=now --no-edit

[pull]
	rebase = true

[commit]
       verbose = true

[include]
	path = ~/.gitconfig.local
