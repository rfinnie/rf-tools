#!/bin/sh

# SPDX-PackageName: rf-tools
# SPDX-PackageSupplier: Ryan Finnie <ryan@finnie.org>
# SPDX-PackageDownloadLocation: https://github.com/rfinnie/rf-tools
# SPDX-FileComment: randmac
# SPDX-FileCopyrightText: © 2016 Ryan Finnie <ryan@finnie.org>
# SPDX-License-Identifier: MPL-2.0

OUI="52:54:00"
if [ -e /proc/sys/kernel/random/uuid ]; then
    MACADDR="${OUI}:$(sed 's/^.*\(..\)\(..\)\(..\)$/\1:\2:\3/' </proc/sys/kernel/random/uuid)"
else
    MACADDR="${OUI}:$(dd if=/dev/urandom count=1 2>/dev/null | md5sum | sed 's/^\(..\)\(..\)\(..\).*$/\1:\2:\3/')"
fi

echo $MACADDR
