# Sample config.yaml:
#
# profiles:
#   myaccount:
#     site: "https://example.com"
#     api_key: "APIKEY"
#     username: "foo"
#     data_dir: "/path/to/data"
#
# One or both of username or api_key are required. If username is not
# specified, the API key's logged in user is used.

import argparse
import datetime
import json
import logging
import math
import os
import pathlib
import random
import re
import sys
import time

import dateutil.parser
import requests
import yaml


# SPDX-SnippetBegin
# SPDX-SnippetName: ratelimit_sleep_time from rf-pymods
# SPDX-SnippetComment: Revision 2026-05-14
# SPDX-SnippetComment: Originally from https://forge.colobox.com/rfinnie/rf-pymods
# SPDX-SnippetCopyrightText: © 2026 Ryan Finnie <ryan@finnie.org>
# SPDX-License-Identifier: MIT
def ratelimit_sleep_time(response: requests.Response, accel: float = 10.0, leniency: float = 1.0) -> datetime.timedelta:
    """Determine sleep time from a requests response with ratelimit headers

    response: Logarithmic acceleration factor
    accel: Format string of default repr/str output
    leniency: Seconds to add if next request lands right on the reset
    """
    if not all([response.headers.get(x) for x in ["date", "x-ratelimit-limit", "x-ratelimit-remaining", "x-ratelimit-reset"]]):
        # If no ratelimit info is present, return an empty timedelta,
        # which can still be used for time.sleep(t.total_seconds()) (zero)
        return datetime.timedelta()
    # If it's less than [leniency] seconds before reset, return [leniency] instead of the caluclated time
    leniency_td = datetime.timedelta(seconds=leniency)
    # Cutoff point to determine if a number is a millisecond Unix epoch, a second Unix epoch, or a delta
    guess_epoch_td = datetime.datetime(2000, 1, 1, 0, 0, tzinfo=datetime.timezone.utc)
    api_current_ts = dateutil.parser.parse(response.headers.get("date"))
    api_limit = float(response.headers.get("x-ratelimit-limit"))
    api_remaining = float(response.headers.get("x-ratelimit-remaining"))
    api_reset_ts = None
    try:
        reset_float = float(response.headers.get("x-ratelimit-reset"))
    except ValueError:
        # ISO 8601 (Mastodon, Jira, etc)
        api_reset_ts = dateutil.parser.parse(response.headers.get("x-ratelimit-reset"))
    if api_reset_ts is None:
        if reset_float > (guess_epoch_td.timestamp() * 1000.0):
            # Epoch time, milliseconds
            api_reset_ts = datetime.datetime.fromtimestamp(reset_float / 1000.0, tz=datetime.timezone.utc)
        elif reset_float > guess_epoch_td.timestamp():
            # Epoch time, seconds (GitHub, etc)
            api_reset_ts = datetime.datetime.fromtimestamp(reset_float, tz=datetime.timezone.utc)
        else:
            # Delta, seconds
            api_reset_ts = api_current_ts + datetime.timedelta(seconds=reset_float)
    if api_reset_ts < api_current_ts:
        # Handle negative cases
        api_reset_ts = api_current_ts
    # Time remaining until reset
    api_reset_td = api_reset_ts - api_current_ts
    logging.debug(
        "Rate limit: {}/{} remaining until {} ({})".format(
            api_remaining,
            api_limit,
            api_reset_ts,
            api_reset_td,
        )
    )
    if api_remaining <= 0:
        # No remaining request, wait until reset
        return api_reset_td + leniency_td
    if api_reset_td < leniency_td:
        # If it's less than [leniency] seconds before reset, return [leniency] instead of the caluclated time
        return leniency_td
    if accel > 1:
        # Logarithmic weighting of faster requests at the beginning of a window
        sleep_td = api_reset_td / (api_remaining + 1) * math.log(api_limit / api_remaining, accel)
    else:
        # Even distribution of requests throughout the window
        sleep_td = api_reset_td / (api_remaining + 1)
    if sleep_td >= api_reset_td:
        # Avoid lining up a future request exactly at (or greatly after) the reset time
        sleep_td = api_reset_td + leniency_td
    return sleep_td


# SPDX-SnippetEnd


XDG_CONFIG_HOME = os.environ.get("XDG_CONFIG_HOME", pathlib.Path("~", ".config").expanduser())
XDG_DATA_HOME = os.environ.get("XDG_DATA_HOME", pathlib.Path("~", ".local", "share").expanduser())


class MastodonDownloader:
    site = None
    api_key = None
    data_dir = None
    username = None

    re_links = re.compile(r"<(?P<url>.*?)>; rel=\"(?P<link>.*?)\"")
    user_id = None
    args = None

    def __init__(self):
        self.requests_session = requests.Session()
        url = "https://forge.colobox.com/rfinnie/rf-tools/src/HEAD/bin/mastodon-downloader"
        self.requests_session.headers.update(
            {"User-Agent": "{} (mastodon-downloader; +{})".format(requests.utils.default_user_agent(), url)}
        )

    def load_config(self):
        with self.args.config.open() as f:
            y = yaml.safe_load(f)
        self.profiles = []
        if y.get("site"):
            profile = {"name": "default"}
            for k in ("data_dir", "site", "api_key", "username", "exclude_reblogs", "exclude_replies"):
                if k in y:
                    profile[k] = y[k]
            self.profiles.append(profile)
        for profile_name, profile in y.get("profiles", {}).items():
            profile["name"] = profile_name
            self.profiles.append(profile)
        for profile in self.profiles:
            profile["data_dir"] = pathlib.Path(
                profile.get("data_dir", pathlib.Path(XDG_DATA_HOME, "mastodon-downloader", "profiles", profile["name"]))
            )
            profile["site"] = profile.get("site")
            profile["api_key"] = profile.get("api_key")
            profile["username"] = profile.get("username")
            profile["exclude_reblogs"] = profile.get("exclude_reblogs", True)
            profile["exclude_replies"] = profile.get("exclude_replies", False)
            profile["all_profiles"] = profile.get("all_profiles", True)

    def parse_args(self, argv=None):
        if argv is None:
            argv = sys.argv

        parser = argparse.ArgumentParser(
            formatter_class=argparse.ArgumentDefaultsHelpFormatter,
        )

        parser.add_argument(
            "--config",
            type=pathlib.Path,
            default=pathlib.Path(XDG_CONFIG_HOME, "mastodon-downloader", "mastodon-downloader.yaml"),
            help="Configuration file",
        )
        parser.add_argument(
            "--profile",
            dest="profiles",
            type=str,
            action="append",
            default=[],
            help="Profile to run, default all",
        )
        parser.add_argument(
            "--refresh",
            type=int,
            default=0,
            help="Number of random downloaded posts to refresh",
        )
        parser.add_argument(
            "--debug",
            action="store_true",
            help="output additional debugging information",
        )

        return parser.parse_args(args=argv[1:])

    def download_attachments(self, profile, item):
        created_at = dateutil.parser.parse(item["created_at"])
        for i, attachment in enumerate(item.get("media_attachments", []), start=1):
            ext = attachment["url"].split(".")[-1]
            fn = pathlib.Path(profile["data_dir"], "{}-{}.{}".format(item["id"], i, ext))
            r = self.requests_session.request("GET", attachment["url"])
            r.raise_for_status()
            logging.info("{} {}: Saving {} attachment to {}".format(profile["name"], item["id"], attachment["type"], fn))
            with fn.open("wb") as f:
                for chunk in r.iter_content(chunk_size=1024):
                    if chunk:
                        f.write(chunk)
            os.utime(
                str(fn),
                (created_at.timestamp(), created_at.timestamp()),
            )

    def api_sleep(self, r):
        sleep_time = ratelimit_sleep_time(r)
        if sleep_time:
            logging.debug("Sleeping {} for rate limit".format(sleep_time))
            time.sleep(sleep_time.total_seconds())

    def refresh_posts(self, profile, num_posts):
        jsons = list(pathlib.Path(profile["data_dir"]).glob("*.json"))
        if num_posts > len(jsons):
            num_posts = len(jsons)
        rand_jsons = random.choices(jsons, k=num_posts)
        for json_fn in rand_jsons:
            with json_fn.open() as f:
                saved_j = json.load(f)

            r = self.requests_session.request(
                "GET",
                "{}/api/v1/statuses/{}".format(profile["site"], saved_j["id"]),
                headers=profile["api_headers"],
            )
            try:
                r.raise_for_status()
            except requests.exceptions.HTTPError:
                if r.status_code == 404:
                    logging.info("{} {}: Post no longer exists".format(profile["name"], saved_j["id"]))
                    self.api_sleep(r)
                    continue
                else:
                    raise
            item = r.json()

            saved_edited_at = dateutil.parser.parse(saved_j["edited_at"] if saved_j["edited_at"] else saved_j["created_at"])
            logging.debug(
                "{} {} saved: {}/{}/{}, {}".format(
                    profile["name"],
                    saved_j["id"],
                    saved_j["replies_count"],
                    saved_j["reblogs_count"],
                    saved_j["favourites_count"],
                    saved_edited_at,
                )
            )
            edited_at = dateutil.parser.parse(item["edited_at"] if item["edited_at"] else item["created_at"])
            logging.debug(
                "{} {} api: {}/{}/{}, {}".format(
                    profile["name"],
                    item["id"],
                    item["replies_count"],
                    item["reblogs_count"],
                    item["favourites_count"],
                    edited_at,
                )
            )
            if (
                (edited_at > saved_edited_at)
                or (item["replies_count"] > saved_j["replies_count"])
                or (item["reblogs_count"] > saved_j["reblogs_count"])
                or (item["favourites_count"] > saved_j["favourites_count"])
            ):
                logging.info("{} {}: Saving updated post".format(profile["name"], item["id"]))
                self.save_item(profile, item)
            self.api_sleep(r)

    def save_item(self, profile, item):
        edited_at = dateutil.parser.parse(item["edited_at"] if item["edited_at"] else item["created_at"])
        json_fn = pathlib.Path(profile["data_dir"], "{}.json".format(item["id"]))
        logging.info(
            "{} {}: Saving {} post from {} to {}".format(profile["name"], item["id"], item["visibility"], edited_at, json_fn)
        )
        self.download_attachments(profile, item)
        with json_fn.open("w") as f:
            json.dump(item, f, sort_keys=True, indent=4)
        os.utime(str(json_fn), (edited_at.timestamp(), edited_at.timestamp()))

    def main(self):
        self.args = self.parse_args()
        logging.basicConfig(level=(logging.DEBUG if self.args.debug else logging.INFO))
        self.load_config()

        if self.args.profiles:
            profiles = [profile for profile in self.profiles if profile["name"] in self.args.profiles]
        else:
            profiles = [profile for profile in self.profiles if profile["all_profiles"]]
        for profile in profiles:
            self.run_profile(profile)

    def run_profile(self, profile):
        profile["api_headers"] = {}
        if profile["api_key"]:
            profile["api_headers"]["Authorization"] = "Bearer {}".format(profile["api_key"])

        if profile["username"]:
            r = self.requests_session.request(
                "GET",
                "{}/api/v1/accounts/lookup".format(profile["site"]),
                params={"acct": profile["username"]},
                headers=profile["api_headers"],
            )
            r.raise_for_status()
            acct = r.json()
            profile["user_id"] = acct["id"]
            logging.info("{}: User is: {} ({})".format(profile["name"], acct["display_name"], acct["username"]))
        elif profile["api_key"]:
            r = self.requests_session.request(
                "GET",
                "{}/api/v1/accounts/verify_credentials".format(profile["site"]),
                headers=profile["api_headers"],
            )
            r.raise_for_status()
            me = r.json()
            profile["user_id"] = me["id"]
            logging.info("{}: I am {} ({})".format(profile["name"], me["display_name"], me["username"]))
        else:
            logging.error("Neither username nor api_key specified, don't know who to look up")
            return 1

        if self.args.refresh:
            return self.refresh_posts(profile, self.args.refresh)

        self.account_info(profile)
        profile["data_dir"].mkdir(parents=True, exist_ok=True)
        try:
            last_json = sorted(pathlib.Path(profile["data_dir"]).glob("*.json"))[-1]
            with last_json.open() as f:
                j = json.load(f)
            last_id = j["id"]
        except IndexError:
            last_id = "0"
        logging.info("{}: Beginning at post {}".format(profile["name"], last_id))
        params = {
            "min_id": last_id,
            "exclude_reblogs": ("true" if profile["exclude_reblogs"] else "false"),
            "exclude_replies": ("true" if profile["exclude_replies"] else "false"),
        }
        url = "{}/api/v1/accounts/{}/statuses".format(profile["site"], profile["user_id"])
        while url:
            r = self.requests_session.request("GET", url, params=params, headers=profile["api_headers"])
            r.raise_for_status()
            items = r.json()
            if not items:
                break
            for item in items:
                self.save_item(profile, item)
            links = {x[1]: x[0] for x in self.re_links.findall(r.headers.get("link", ""))}
            url = links.get("prev")
            params = {}
            self.api_sleep(r)

    def account_info(self, profile):
        out = {
            "followers": [],
            "following": [],
        }
        for k, v in out.items():
            url = "{}/api/v1/accounts/{}/{}".format(profile["site"], profile["user_id"], k)
            params = {}
            while url:
                r = self.requests_session.request("GET", url, params=params, headers=profile["api_headers"])
                r.raise_for_status()
                items = r.json()
                if not items:
                    break
                v.extend(items)
                links = {x[1]: x[0] for x in self.re_links.findall(r.headers.get("link", ""))}
                url = links.get("next")
                params = {}
                self.api_sleep(r)

        r = self.requests_session.request(
            "GET",
            "{}/api/v1/accounts/{}".format(profile["site"], profile["user_id"]),
            headers=profile["api_headers"],
        )
        r.raise_for_status()
        out["account"] = r.json()
        account_dir = pathlib.Path(profile["data_dir"], "account")
        json_fn = pathlib.Path(
            account_dir,
            "account-{}.json".format(datetime.datetime.now(tz=datetime.timezone.utc).strftime("%Y%m%d%H%M%S%f")),
        )
        account_dir.mkdir(parents=True, exist_ok=True)
        with json_fn.open("w") as f:
            json.dump(out, f, sort_keys=True, indent=4)


if __name__ == "__main__":
    sys.exit(MastodonDownloader().main())
