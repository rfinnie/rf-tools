#!/bin/sh

# SPDX-PackageName: rf-tools
# SPDX-PackageSupplier: Ryan Finnie <ryan@finnie.org>
# SPDX-PackageDownloadLocation: https://github.com/rfinnie/rf-tools
# SPDX-FileComment: curl-over-there
# SPDX-FileCopyrightText: © 2020 Ryan Finnie <ryan@finnie.org>
# SPDX-License-Identifier: MPL-2.0

set -e

if [ -z "$1" ]; then
    echo "Usage: curl-over-there ip curl_arguments" >&2
    echo >&2
    echo "Example: curl-over-there 1.2.3.4 -v -H \"Foo: bar\" https://www.example.com/" >&2
    exit 1
fi
ADDR="$1"; shift
exec curl --resolve "*:80:${ADDR}" --resolve "*:443:${ADDR}" "$@"
