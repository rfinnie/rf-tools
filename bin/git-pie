#!/usr/bin/env python3

# SPDX-PackageName: rf-tools
# SPDX-PackageSupplier: Ryan Finnie <ryan@finnie.org>
# SPDX-PackageDownloadLocation: https://codeberg.org/rfinnie/rf-tools
# SPDX-FileComment: git-pie
# SPDX-FileCopyrightText: © 2020 Ryan Finnie <ryan@finnie.org>
# SPDX-License-Identifier: MPL-2.0

# Usage:
#     git pie 's/foo/bar/g'
#     git pie '/^matchtext: / && s/foo/bar/g'
#
# Equivalent to running: perl -pi -e 's/foo/bar/g'
# on all git-managed files in a directory, though the match portion is
# run through git grep first so Perl does not update the mtime on
# non-matching files.

import argparse
import logging
import os
import subprocess
import sys


# Git will hijack `git pie --help`, so display full help upon error
class FullHelpParser(argparse.ArgumentParser):
    def error(self, message):
        self.print_help()
        print()
        print("{}: error: {}".format(self.prog, message))
        sys.exit(2)


class GitPie:
    def __init__(self):
        self.logger = logging.getLogger(self.__class__.__name__)

    def parse_args(self, argv=None):
        if argv is None:
            argv = sys.argv

        parser = FullHelpParser(
            formatter_class=argparse.ArgumentDefaultsHelpFormatter,
            prog=os.path.basename(argv[0]),
        )

        parser.add_argument(
            "expression",
            help="Expression to run on matched files (Perl)",
        )
        parser.add_argument(
            "--match",
            help="Match string (Git PCRE), optional if match can be guessed from expression (e.g. simple s///)",
        )
        parser.add_argument(
            "--debug",
            action="store_true",
            help="output additional debugging information",
        )

        args = parser.parse_args(args=argv[1:])
        if not args.match:
            args.match = self.get_match(args.expression)
        if not args.match:
            parser.error("--match is needed for given expression")
        return args

    def get_match(self, expression):
        if len(expression) < 2:
            return
        if expression.startswith("s") or expression.startswith("m"):
            expression = expression[1:]
        separator = expression[0]
        if separator.isalnum() or separator == " ":
            return
        for i, c in enumerate(expression[1:]):
            if c == separator and expression[1 + i] != "\\":
                break
        return expression[1 : 1 + i]

    def main(self):
        self.args = self.parse_args()
        logging.basicConfig(
            level=(logging.DEBUG if self.args.debug else logging.INFO),
            format="%(name)s %(levelname)s: %(message)s",
        )
        command = ["git", "grep", "-l", "-z", "-P", "--", self.args.match]
        self.logger.debug("Running: {}".format(command))
        try:
            output = subprocess.check_output(command, encoding="UTF-8")
        except subprocess.CalledProcessError as e:
            return e.returncode

        files_matched = [x for x in output.split("\0") if x != ""]
        if files_matched:
            for file in files_matched:
                self.logger.debug("Matched: {}".format(file))
        else:
            self.logger.debug("No files matched")
            return 1

        command = ["perl", "-CSD", "-Mutf8", "-pi", "-e", self.args.expression, *files_matched]
        self.logger.debug("Running: {}".format(command))
        subprocess.check_call(command, encoding="UTF-8")


if __name__ == "__main__":
    sys.exit(GitPie().main())
