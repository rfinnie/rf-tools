#!/usr/bin/env python3

# SPDX-PackageName: rf-tools
# SPDX-PackageSupplier: Ryan Finnie <ryan@finnie.org>
# SPDX-PackageDownloadLocation: https://github.com/rfinnie/rf-tools
# SPDX-FileComment: apt-rogue-packages - Compares installed Debian packages to available
# SPDX-FileCopyrightText: © 2010 Ryan Finnie <ryan@finnie.org>
# SPDX-License-Identifier: MPL-2.0

import argparse
import glob
import logging
import os
import sys


class AptRoguePackages:
    def __init__(self):
        self.logger = logging.getLogger(self.__class__.__name__)
        self.missing = set()

    def parse_args(self, argv=None):
        if argv is None:
            argv = sys.argv

        parser = argparse.ArgumentParser(
            formatter_class=argparse.ArgumentDefaultsHelpFormatter,
            prog=os.path.basename(argv[0]),
        )

        parser.add_argument(
            "--status-files",
            default="/var/lib/dpkg/status",
            help="dpkg status files (glob)",
        )

        parser.add_argument(
            "--apt-files",
            default="/var/lib/apt/lists/*_Packages",
            help="apt files (glob)",
        )

        parser.add_argument(
            "--debug",
            action="store_true",
            help="output additional debugging information",
        )

        return parser.parse_args(args=argv[1:])

    def read_blocks(self, fh):
        block = {}
        last_key = None
        for lineno, line in enumerate(fh, start=1):
            line = line.rstrip()
            if line == "":
                if block:
                    yield block
                else:
                    self.logger.warning("Line {}: Invalid double block ending".format(lineno))
                block = {}
                last_key = None
                continue
            if line.startswith(" "):
                if last_key:
                    if block[last_key]:
                        block[last_key] += "\n" + line.lstrip()
                    else:
                        block[last_key] += line.lstrip()
                continue
            parts = line.split(":", 1)
            if len(parts) < 2:
                self.logger.warning("Line {}: Invalid format".format(lineno))
                continue
            last_key = parts[0].lower()
            block[last_key] = parts[1].lstrip()
        if block:
            yield block
        self.logger.debug("Parsed {} lines".format(lineno))

    def process_block(self, block, mode):
        if mode == "status":
            if "not-installed" in block.get("status"):
                return
            if not block.get("package") or not block.get("status") or not block.get("version") or not block.get("architecture"):
                self.logger.warning("Cannot figure out block: {}".format(block))
                return

        # Append the architecture.  If it's "all", don't include it. ("all"
        # is an acceptable architecture in apt operations, but isn't needed.)
        if block["architecture"] == "all":
            package = "{}={}".format(block["package"], block["version"])
        else:
            package = "{}:{}={}".format(block["package"], block["architecture"], block["version"])

        if mode == "status":
            # Add status package to be checked later
            self.missing.add(package)
        else:
            # Remove from status missing, if found
            if package in self.missing:
                self.missing.remove(package)

    def main(self):
        self.args = self.parse_args()
        logging.basicConfig(
            level=(logging.DEBUG if self.args.debug else logging.INFO),
            format="%(name)s %(levelname)s: %(message)s",
        )

        # Gather the status packages
        for fn in glob.glob(self.args.status_files):
            self.logger.debug("Process status file: {}".format(fn))
            with open(fn) as fh:
                for block in self.read_blocks(fh):
                    self.process_block(block, "status")

        # Process the available apt caches
        for fn in glob.glob(self.args.apt_files):
            self.logger.debug("Process apt file: {}".format(fn))
            with open(fn) as fh:
                for block in self.read_blocks(fh):
                    self.process_block(block, "aptfiles")

        # Output remaining missing packages
        for package in sorted(self.missing):
            print(package)


if __name__ == "__main__":
    sys.exit(AptRoguePackages().main())
